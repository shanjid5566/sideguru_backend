    {
      "name": "Admin Categories",
      "item": [
        {
          "name": "Update/Delete Service Category or Subcategory",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{serviceCategoryId}}\",\n  \"categoryName\": \"Updated Service Category Name\",\n  \"subcategoryId\": \"{{subCategoryId}}\",\n  \"subcategoryName\": \"Updated Subcategory Name\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/categories/service",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "categories",
                "service"
              ]
            },
            "description": "Use categoryName or subcategoryName as null/empty string to delete the target."
          },
          "response": []
        },
        {
          "name": "Update/Delete Event Category",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{eventCategoryId}}\",\n  \"categoryName\": \"Updated Event Category Name\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/categories/event",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "categories",
                "event"
              ]
            },
            "description": "Set categoryName to null or empty string to delete the event category."
          },
          "response": []
        }
      ]
    }
  ],
